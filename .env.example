# ==============================================================================
# .env.example — copy to .env and fill in secrets
# NEVER commit .env to version control
# ==============================================================================

# ── Label Studio Integration ───────────────────────────────────────────────────
LABEL_STUDIO_URL=http://localhost:8080
LABEL_STUDIO_TOKEN=your-label-studio-api-token-here
LABEL_STUDIO_PROJECT_ID=1

# ── Feedback Database ──────────────────────────────────────────────────────────
# SQLite (default, for development):
FEEDBACK_DB_URL=sqlite:///./logs/feedback.db
# PostgreSQL (for production):
# FEEDBACK_DB_URL=postgresql+asyncpg://user:password@db-host:5432/hrm_ocr

# ── API Settings ───────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
LOG_LEVEL=info

# ── OCR Engine ─────────────────────────────────────────────────────────────────
# These override configs/default.yaml values
# PADDLE_USE_GPU=false   # Keep false — CPU only deployment
# OCR_LANG=en

# ── Image serving (for Label Studio task URLs) ─────────────────────────────────
IMAGE_BASE_URL=http://localhost:8000/images
